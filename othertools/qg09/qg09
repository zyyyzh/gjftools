# TODO: read PROC_NUM from input file automatically

#! /bin/bash
usageline='''Usage: [-p PROC_NUM(=4)] [-x ISXTB (gauxtb)] [-c ISCONFORMATION (rpipfmin)] [-t ISCREST] [-s ISsobEDA] [-a ISALL] [-f INPUTNAME] [-q FILTER_HOST] [-k need_autofix] [-g use_g16]'''

while getopts p:xctsaf:q:kg OPT; do #选项后面的冒号表示该选项需要参数
  case ${OPT} in
    p) PROC_NUM=${OPTARG} #使用处理器数
       ;;
    x) ISXTB=${OPTIND} # 是否为xtb任务
       ;;
    c) ISCONFORMATION=${OPTIND} # 是否为cf任务
       ;;
    t) ISCREST=${OPTIND} # 是否为CREST任务
       ;;
    s) ISsobEDA=${OPTIND} # 是否为sobEDA任务
       ;;
    a) ISALL=${OPTIND} # 是否为全部提交
       ;;
    f) INPUTNAME=${OPTARG} #执行文件名
       ;;
    q) FILTER_HOST=${OPTARG} # 选择或忽略某个host
       ;;
    k) AUTOFIX=${OPTIND} # 是否执行autofix
       ;;
    g) G16=${OPTIND} # 是否使用g16
       ;;
    \?)
      #  printf $usageline $(basename $0) >&2
       echo $usageline
       exit 1
  esac
done

# no input file
if [ -z $ISALL ] && [ -z $INPUTNAME ]; then
  echo $usageline
  exit 1
fi

# detect job type
if [ -n "$ISXTB" ]; then
  echo 'Job type: gau-xtb'
  qsub_file=g09xtb01
elif [ -n "$ISCONFORMATION" ]; then
  echo 'Job type: rpipfmin'
  qsub_file=yzhcf801
elif [ -n "$ISCREST" ]; then
  echo 'Job type: CREST'
  qsub_file=yzhcrest01
elif [ -n "$ISsobEDA" ]; then
  echo 'Job type: sobeda'
  qsub_file=g16sobeda
elif [ -n "$G16" ]; then
  echo 'Job type: G16'
  qsub_file=g16yzh01
elif [ -n "$AUTOFIX" ]; then
  echo 'Job type: G09 with autofix'
  qsub_file=g09yzh01fix
else  # default
  echo 'Job type: G09'
  qsub_file=g09yzh01
fi

# set default proc num according to job type
if [ -z $PROC_NUM ]; then
  if [ -n "$ISXTB" ]; then
    PROC_NUM=1
  elif [ -n "$ISCONFORMATION" ]; then
    PROC_NUM=8
  elif [ -n "$ISCREST" ]; then
    PROC_NUM=4
  elif [ -n "$ISsobEDA" ]; then
    PROC_NUM=8
  else
    PROC_NUM=4
  fi
fi

# detect submit type (filter host or not)
if [ -z $FILTER_HOST ]; then
  qsub_cmd='qsub -v JOBNAME=$JOBNAME,INPUTNAME=$INPUTNAME,DIR_NAME=$DIR_NAME -cwd -j y -S /bin/bash -pe smp $PROC_NUM -N $JOBNAME $(dirname $0)/$qsub_file'
else
  qsub_cmd='qsub -q all.q@$FILTER_HOST -v JOBNAME=$JOBNAME,INPUTNAME=$INPUTNAME,DIR_NAME=$DIR_NAME -cwd -j y -S /bin/bash -pe smp $PROC_NUM -N $JOBNAME $(dirname $0)/$qsub_file'
fi


# submit all
if [ -n "$ISALL" ]; then
  # crest jobs (xyz input)
  if [ -n "$ISCREST" ]; then
    for file in *.xyz; do
      if [ ! -f ${file%.*}.o* ] && [ ! -f ${file%.*}.po* ]; then
        INPUTNAME=$(basename $file)
        JOBNAME=${INPUTNAME%.*}
        DIR_NAME=$(dirname $INPUTNAME)
        if [ $DIR_NAME = '.' ]; then
          DIR_NAME=`pwd`
        fi
        printf "Input file directory: %s \n" $DIR_NAME
        printf "Input file name: %s \n" $INPUTNAME
        printf "Job name: %s \n" $JOBNAME
        printf "Number of processors: %s \n" $PROC_NUM
        eval "$qsub_cmd"
      fi
    done
  # sobEDA jobs (do not support)
  elif [ -n "$ISsobEDA" ]; then
    echo "sobEDA job do not support submit all function, please submit jobs manually!"
    echo $usageline
    exit 1
  # other jobs (gjf input)
  else
    for file in *.gjf; do
      if [ ! -f ${file%.*}.o* ] && [ ! -f ${file%.*}.po* ]; then
        INPUTNAME=$(basename $file)
        JOBNAME=${INPUTNAME%.*}
        DIR_NAME=$(dirname $INPUTNAME)
        if [ $DIR_NAME = '.' ]; then
          DIR_NAME=`pwd`
        fi
        printf "Input file directory: %s \n" $DIR_NAME
        printf "Input file name: %s \n" $INPUTNAME
        printf "Job name: %s \n" $JOBNAME
        printf "Number of processors: %s \n" $PROC_NUM
        eval "$qsub_cmd"
      fi
    done
  fi

# submit one
else
  # define basic variables
  FILENAME=$(basename $INPUTNAME)
  JOBNAME=${FILENAME%.*}
  DIR_NAME=$(dirname $INPUTNAME)
  if [ $DIR_NAME = '.' ]; then
    DIR_NAME=`pwd`
  fi

  printf "Input file directory: %s \n" $DIR_NAME
  printf "Input file name: %s \n" $INPUTNAME
  printf "Job name: %s \n" $JOBNAME
  printf "Number of processors: %s \n" $PROC_NUM
  eval "$qsub_cmd"
fi
printf "\n"

